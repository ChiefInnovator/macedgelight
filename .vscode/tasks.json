{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "make build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$swiftc"
      ],
      "presentation": {
        "reveal": "silent",
        "revealProblems": "onProblem"
      }
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "make release",
      "group": "build",
      "problemMatcher": [
        "$swiftc"
      ]
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make clean",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
